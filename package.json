{
  "name": "delta-sync",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Delta-Sync middleware and React hook to reduce polling payload bandwidth via RFC 6902 patches.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "tsx scripts/delta-benchmark.ts",
    "demo": "tsx src/demo/server.ts"
  },
  "dependencies": {
    "compression": "^1.8.0",
    "express": "^4.21.2",
    "fast-json-patch": "^3.1.1",
    "fast-json-stable-stringify": "^2.1.0",
    "jsondiffpatch": "^0.6.0",
    "lru-cache": "^10.4.3",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^6.0.3",
    "jsdom": "^26.1.0",
    "supertest": "^7.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
